<!DOCTYPE html>
<html>
<head>
    <title>Student Form</title>
</head>
<body>

    <h1>Enter Student Details</h1>

    <form action="/result" method="POST">
        <label>Name:</label>
        <input type="text" name="name" required><br><br>

        <label>Marks:</label>
        <input type="number" name="marks" required><br><br>

        <button type="submit">Submit</button>
    </form>

</body>
</html>