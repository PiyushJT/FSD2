// Write an express JS to upload file with size limit of 10 MB to a specific directory named Data on the server and in this folder 
// file must be store in format of lju-file.pdf where LJU is the field name
const multer = require("multer")
const express = require("express")
app = express()     
app.use(express.static(__dirname, { index: 'file.html' }))
var store = multer.diskStorage({
    destination: "Data",
    filename: (req, file, cb) => {
        cb(null, "lju-" + file.originalname)
    }
})
var upload = multer({ storage: store, limits: { fileSize: 10 * 1024 * 1024 } })
app.post("/upload", upload.single("LJU"), (req, res) => {
    const file = req.file
    if (file) {
        res.send("file " + file.originalname + " has been upload in " + file.destination + " folder")
    }
})
app.listen(3200)